---
import '../styles/global.css';
import type { Lang } from '../i18n';

interface Props { lang: Lang; title?: string }
const { lang, title = 'Cristóbal — designer, entrepreneur & product builder' } = Astro.props;
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="data:," />
    <title>{title}</title>
    <meta name="description" content="Cristóbal — designer, entrepreneur and product builder across applied AI, digital tools and 3D fabrication." />
    <link rel="alternate" hreflang="es" href="https://chrispiz.cl/es" />
    <link rel="alternate" hreflang="en" href="https://chrispiz.cl/en" />
    <link rel="alternate" hreflang="x-default" href="https://chrispiz.cl/" />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('cb-theme');
        const theme = saved
          ? saved
          : (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import NowPlaying from '../components/NowPlaying.astro';
import AvailableCard from '../components/AvailableCard.astro';
import StackCard from '../components/StackCard.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../data/projects';

const lang = 'en';
---
<Base lang={lang}>
  <main class="mx-auto max-w-5xl px-5 py-10 sm:py-16 flex flex-col gap-10">
    <Hero lang={lang} />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-1 gap-4">
        {projects.map((p) => <ProjectCard project={p} lang={lang} />)}
      </div>
      <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4 content-start">
        <NowPlaying lang={lang} />
        <AvailableCard lang={lang} />
        <div class="sm:col-span-2"><StackCard lang={lang} /></div>
      </div>
    </div>
    <Footer />
  </main>
</Base>

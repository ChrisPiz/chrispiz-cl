---
// Language detector. Runs on the server (prerender=false), reads the visitor's
// browser language and redirects to /en or /es. A manual choice (cookie) wins.
export const prerender = false;

const cookie = Astro.cookies.get('lang')?.value;
const accept = (Astro.request.headers.get('accept-language') ?? '').toLowerCase();

let target = '/en'; // default for English & any non-Spanish browser
if (cookie === 'es') target = '/es';
else if (cookie === 'en') target = '/en';
else if (accept.startsWith('es')) target = '/es';

return Astro.redirect(target, 302);
---

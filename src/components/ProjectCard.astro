---
import type { Project } from '../data/projects';
import type { Lang } from '../i18n';
const { project, lang } = Astro.props as { project: Project; lang: Lang };
const marks: Record<string, string> = {
  triangle: '<path d="M12 4l8 14H4z" fill="currentColor"/>',
  square: '<rect x="5" y="5" width="14" height="14" rx="2" fill="currentColor"/>',
  circle: '<circle cx="12" cy="12" r="8" fill="currentColor"/>',
};
---
<a class={`card proj ${project.cls} ${project.area}`} href={project.url} target="_blank" rel="noopener">
  <svg class="mark" viewBox="0 0 24 24" aria-hidden="true" set:html={marks[project.mark]} />
  <h3>{project.name}</h3>
  <p>{project.blurb[lang]}</p>
  <span class="arrow">→</span>
</a>

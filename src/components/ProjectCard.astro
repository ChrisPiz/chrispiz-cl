---
import type { Project } from '../data/projects';
import type { Lang } from '../i18n';
const { project, lang } = Astro.props as { project: Project; lang: Lang };
const marks: Record<string, string> = {
  triangle: '<path d="M12 4l8 14H4z" fill="currentColor"/>',
  square: '<rect x="5" y="5" width="14" height="14" rx="2" fill="currentColor"/>',
  circle: '<circle cx="12" cy="12" r="8" fill="currentColor"/>',
};
const host = new URL(project.url).host.replace(/^www\./, '');
---
<a class={`card proj ${project.cls} ${project.area}`} href={project.url} target="_blank" rel="noopener">
  {project.area === 'rabbit' && (
    <svg class="deco" viewBox="0 0 100 100" fill="none" aria-hidden="true">
      <path d="M50 10 L88 31 L88 71 L50 92 L12 71 L12 31 Z M12 31 L50 52 L88 31 M50 52 L50 92" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round"/>
    </svg>
  )}
  <svg class="mark" viewBox="0 0 24 24" aria-hidden="true" set:html={marks[project.mark]} />
  <h3>{project.name}</h3>
  <p>{project.blurb[lang]}</p>
  <div class="proj-foot">
    <span class="host">{host}</span>
    <span class="arrow">→</span>
  </div>
</a>

---
import type { Lang } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const other = lang === 'en' ? 'es' : 'en';
const href = other === 'es' ? '/es' : '/';
---
<a href={href} id="lang-toggle" data-lang={other}
  class="h-9 px-3 grid place-items-center rounded-full border text-xs uppercase tracking-wide text-[var(--color-muted)] hover:text-[var(--color-ink)]"
  style="border-color: var(--border-neutral)">{other}</a>
<script is:inline>
  document.getElementById('lang-toggle')?.addEventListener('click', (e) => {
    e.preventDefault();
    const el = e.currentTarget;
    const lang = el.getAttribute('data-lang');
    const href = el.getAttribute('href');
    document.cookie = `lang=${lang}; path=/; max-age=31536000; samesite=lax`;
    window.location.href = href;
  });
</script>

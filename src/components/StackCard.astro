---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
const items = ['Design','Product','AI','Automation','3D Printing','React','TypeScript','Python','FastAPI','Astro','Tailwind','Docker','n8n','Claude','OpenAI','Ollama'];
---
<div class="card info stack">
  <div class="pill-label">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l9 5-9 5-9-5 9-5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M3 13l9 5 9-5" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
    <span>{t.stackLabel}</span>
  </div>
  <div class="chips">
    {items.map((i) => <span class="chip">{i}</span>)}
  </div>
</div>

---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
const items = ['Design','Product','AI','Automation','3D Printing','React','TypeScript','Python','FastAPI','Astro','Tailwind','Docker','n8n','Claude','OpenAI','Ollama'];
---
<section class="rounded-2xl border p-5" style="border-color: var(--border-neutral); background: var(--color-surface)">
  <h2 class="text-sm font-semibold text-[var(--color-muted)] mb-3">{t.sections.stack}</h2>
  <ul class="flex flex-wrap gap-2">
    {items.map((i) => (
      <li class="text-xs px-2.5 py-1 rounded-full" style="background: var(--color-surface-2)">{i}</li>
    ))}
  </ul>
</section>

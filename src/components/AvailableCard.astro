---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
---
<div class="card info avail">
  <div class="pill-label">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    <span>{t.contactLabel}</span>
  </div>
  <p>{t.contactBody}</p>
  <div class="talk">{t.talk} → <a href="mailto:hola@chrispiz.cl">hola@chrispiz.cl</a></div>
</div>

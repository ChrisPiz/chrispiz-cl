---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
---
<div class="card info now">
  <div class="pill-label">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 14v-2a8 8 0 0 1 16 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><rect x="3" y="13" width="4" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="17" y="13" width="4" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
    <span>{t.npLabel}</span>
  </div>
  <div class="np">
    <div class="cover" id="np-cover"></div>
    <span id="np-text">{t.npIdle}</span>
  </div>
</div>
<script is:inline define:vars={{ idle: t.npIdle, recently: t.npRecently }}>
  async function load() {
    try {
      const r = await fetch('/api/now-playing');
      const d = await r.json();
      const cover = document.getElementById('np-cover');
      const text = document.getElementById('np-text');
      if (d && d.title) {
        const who = d.artist ? ' · ' + d.artist : '';
        text.textContent = (d.isPlaying ? '' : recently + ' · ') + d.title + who;
        if (d.albumArt && cover) cover.style.backgroundImage = `url(${d.albumArt})`;
      } else {
        text.textContent = idle;
        if (cover) cover.style.backgroundImage = '';
      }
    } catch (_) { /* fail-soft */ }
  }
  load();
  setInterval(load, 30000);
</script>

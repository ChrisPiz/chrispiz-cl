---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
---
<a class="card info now" id="np-card" rel="noopener">
  <div class="np-head">
    <div class="pill-label">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 14v-2a8 8 0 0 1 16 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><rect x="3" y="13" width="4" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="17" y="13" width="4" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
      <span>{t.npLabel}</span>
    </div>
    <span class="eq" id="np-eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
  </div>
  <div class="np">
    <div class="cover" id="np-cover"></div>
    <div class="np-meta">
      <span class="np-status" id="np-status"></span>
      <span class="np-title" id="np-title">{t.npIdle}</span>
      <span class="np-artist" id="np-artist"></span>
    </div>
    <svg class="np-go" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</a>
<script is:inline define:vars={{ idle: t.npIdle, recently: t.npRecently }}>
  async function load() {
    try {
      const r = await fetch('/api/now-playing');
      const d = await r.json();
      const card = document.getElementById('np-card');
      const cover = document.getElementById('np-cover');
      const status = document.getElementById('np-status');
      const title = document.getElementById('np-title');
      const artist = document.getElementById('np-artist');
      const eq = document.getElementById('np-eq');
      if (d && d.title) {
        status.textContent = d.isPlaying ? '' : recently;
        status.style.display = d.isPlaying ? 'none' : 'block';
        title.textContent = d.title;
        artist.textContent = d.artist || '';
        artist.style.display = d.artist ? 'block' : 'none';
        if (d.albumArt && cover) cover.style.backgroundImage = `url(${d.albumArt})`;
        if (d.url && card) { card.href = d.url; card.target = '_blank'; card.classList.add('has-link'); }
        else if (card) { card.removeAttribute('href'); card.classList.remove('has-link'); }
        if (eq) eq.classList.toggle('playing', !!d.isPlaying);
      } else {
        status.style.display = 'none';
        title.textContent = idle;
        artist.style.display = 'none';
        if (cover) cover.style.backgroundImage = '';
        if (card) { card.removeAttribute('href'); card.classList.remove('has-link'); }
        if (eq) eq.classList.remove('playing');
      }
    } catch (_) { /* fail-soft */ }
  }
  load();
  setInterval(load, 30000);
</script>

---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
const links = [
  { label: 'GitHub', href: 'https://github.com/ChrisPiz' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/cristobalpizarro/' },
  { label: 'X', href: 'https://x.com/Chris_piza' },
  { label: 'Instagram', href: 'https://www.instagram.com/chrispiz_/' },
  { label: 'Email', href: 'mailto:hola@chrispiz.cl' },
];
---
<div class="card info intro">
  <div class="avatar"><img src="/avatar.png" alt="Cristóbal" /></div>
  <h1 class="hero">{t.hero} <span class="muted">{t.heroMuted}</span></h1>
  <p class="sub">{t.sub}</p>
  <div class="foot-row">
    <span class="pill"><span class="dot"></span>{t.available}</span>
    <nav class="social">
      {links.map((l) => (
        <a
          href={l.href}
          target={l.href.startsWith('http') ? '_blank' : undefined}
          rel={l.href.startsWith('http') ? 'noopener' : undefined}
        >{l.label}</a>
      ))}
    </nav>
  </div>
</div>

---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
---
<div class="card info stack loc">
  <div class="map">
    <svg viewBox="0 0 200 200" fill="none" aria-hidden="true">
      <g class="streets" transform="rotate(-12 100 100)">
        <!-- vertical streets -->
        <line class="road" x1="20" y1="-30" x2="20" y2="230"/>
        <line class="road" x1="50" y1="-30" x2="50" y2="230"/>
        <line class="road" x1="80" y1="-30" x2="80" y2="230"/>
        <line class="road" x1="110" y1="-30" x2="110" y2="230"/>
        <line class="road" x1="140" y1="-30" x2="140" y2="230"/>
        <line class="road" x1="170" y1="-30" x2="170" y2="230"/>
        <line class="road" x1="200" y1="-30" x2="200" y2="230"/>
        <!-- horizontal streets -->
        <line class="road" x1="-30" y1="22" x2="230" y2="22"/>
        <line class="road" x1="-30" y1="52" x2="230" y2="52"/>
        <line class="road" x1="-30" y1="86" x2="230" y2="86"/>
        <line class="road" x1="-30" y1="120" x2="230" y2="120"/>
        <line class="road" x1="-30" y1="152" x2="230" y2="152"/>
        <line class="road" x1="-30" y1="186" x2="230" y2="186"/>
        <!-- main avenue (Alameda) -->
        <line class="avenue" x1="-40" y1="240" x2="240" y2="-40"/>
        <!-- secondary diagonal -->
        <line class="road" x1="240" y1="200" x2="-20" y2="-40"/>
        <!-- río Mapocho -->
        <path class="river" d="M-10 96 C 40 78 78 116 120 96 C 158 78 192 108 212 90"/>
      </g>
    </svg>
    <span class="loc-pin"></span>
  </div>
  <div class="pill-label">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.8"/></svg>
    <span>{t.locLabel}</span>
  </div>
  <div class="loc-body">
    <span class="loc-city">{t.locCity}</span>
    <span class="loc-meta"><span id="loc-time">— GMT-3</span> · {t.locRemote}</span>
  </div>
</div>
<script is:inline>
  (function () {
    function tick() {
      try {
        var s = new Intl.DateTimeFormat('en-GB', {
          hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Santiago',
        }).format(new Date());
        var el = document.getElementById('loc-time');
        if (el) el.textContent = s + ' GMT-3';
      } catch (_) {}
    }
    tick();
    setInterval(tick, 30000);
  })();
</script>

---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
---
<div class="card info stack loc">
  <div class="map">
    <svg viewBox="0 0 200 200" fill="none" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
      <g class="streets">
        <path class="road" d="M-40 192 Q101 107 240 21"/>
        <path class="road" d="M240 -2 Q122 116 10 240"/>
        <path class="road" d="M124 -40 Q28 79 -40 217"/>
        <path class="road" d="M240 131 Q95 74 -11 -40"/>
        <path class="road" d="M240 125 Q102 81 -40 56"/>
        <path class="avenue" d="M240 105 Q158 160 100 240"/>
        <path class="avenue" d="M-40 139 Q42 35 152 -40"/>
        <path class="avenue" d="M240 103 Q130 6 -8 -40"/>
        <path class="road" d="M-40 1 Q-30 142 71 240"/>
        <path class="road" d="M28 -40 Q-12 16 -40 80"/>
        <path class="road" d="M240 170 Q157 224 59 240"/>
        <path class="road" d="M217 -40 Q112 -63 8 -40"/>
        <path class="road" d="M-11 -40 Q130 -7 240 87"/>
        <path class="road" d="M240 80 Q98 50 -40 3"/>
        <path class="road" d="M240 -26 Q285 110 225 240"/>
        <path class="road" d="M240 73 Q97 52 -15 -40"/>
        <path class="road" d="M-40 39 Q80 130 183 240"/>
        <path class="road" d="M-3 -40 Q119 -45 240 -22"/>
        <path class="road" d="M-40 6 Q0 95 -40 184"/>
        <path class="avenue" d="M-40 20 Q103 7 240 52"/>
        <path class="river" d="M-30 70 C 40 50 80 110 130 84 C 170 64 210 100 240 78"/>
      </g>
    </svg>
    <span class="loc-pin"></span>
  </div>
  <div class="pill-label">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.8"/></svg>
    <span>{t.locLabel}</span>
  </div>
  <div class="loc-body">
    <span class="loc-city">{t.locCity}</span>
    <span class="loc-meta"><span id="loc-time">— GMT-3</span> · {t.locRemote}</span>
  </div>
</div>
<script is:inline>
  (function () {
    function tick() {
      try {
        var s = new Intl.DateTimeFormat('en-GB', {
          hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Santiago',
        }).format(new Date());
        var el = document.getElementById('loc-time');
        if (el) el.textContent = s + ' GMT-3';
      } catch (_) {}
    }
    tick();
    setInterval(tick, 30000);
  })();
</script>

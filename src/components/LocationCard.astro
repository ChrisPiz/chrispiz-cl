---
import type { Lang } from '../i18n';
import { getDict } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const t = getDict(lang);
---
<div class="card info stack loc">
  <div class="map">
    <svg viewBox="0 0 200 200" fill="none" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
      <g class="streets" transform="rotate(-12 100 100)">
        <line class="road" x1="-40" y1="-50" x2="-40" y2="250"/>
        <line class="road" x1="-24" y1="-50" x2="-24" y2="250"/>
        <line class="road" x1="-8" y1="-50" x2="-8" y2="250"/>
        <line class="road" x1="8" y1="-50" x2="8" y2="250"/>
        <line class="road" x1="24" y1="-50" x2="24" y2="250"/>
        <line class="road" x1="40" y1="-50" x2="40" y2="250"/>
        <line class="road" x1="56" y1="-50" x2="56" y2="250"/>
        <line class="road" x1="72" y1="-50" x2="72" y2="250"/>
        <line class="road" x1="88" y1="-50" x2="88" y2="250"/>
        <line class="road" x1="104" y1="-50" x2="104" y2="250"/>
        <line class="road" x1="120" y1="-50" x2="120" y2="250"/>
        <line class="road" x1="136" y1="-50" x2="136" y2="250"/>
        <line class="road" x1="152" y1="-50" x2="152" y2="250"/>
        <line class="road" x1="168" y1="-50" x2="168" y2="250"/>
        <line class="road" x1="184" y1="-50" x2="184" y2="250"/>
        <line class="road" x1="200" y1="-50" x2="200" y2="250"/>
        <line class="road" x1="216" y1="-50" x2="216" y2="250"/>
        <line class="road" x1="232" y1="-50" x2="232" y2="250"/>
        <line class="road" x1="-50" y1="-40" x2="250" y2="-40"/>
        <line class="road" x1="-50" y1="-24" x2="250" y2="-24"/>
        <line class="road" x1="-50" y1="-8" x2="250" y2="-8"/>
        <line class="road" x1="-50" y1="8" x2="250" y2="8"/>
        <line class="road" x1="-50" y1="24" x2="250" y2="24"/>
        <line class="road" x1="-50" y1="40" x2="250" y2="40"/>
        <line class="road" x1="-50" y1="56" x2="250" y2="56"/>
        <line class="road" x1="-50" y1="72" x2="250" y2="72"/>
        <line class="road" x1="-50" y1="88" x2="250" y2="88"/>
        <line class="road" x1="-50" y1="104" x2="250" y2="104"/>
        <line class="road" x1="-50" y1="120" x2="250" y2="120"/>
        <line class="road" x1="-50" y1="136" x2="250" y2="136"/>
        <line class="road" x1="-50" y1="152" x2="250" y2="152"/>
        <line class="road" x1="-50" y1="168" x2="250" y2="168"/>
        <line class="road" x1="-50" y1="184" x2="250" y2="184"/>
        <line class="road" x1="-50" y1="200" x2="250" y2="200"/>
        <line class="road" x1="-50" y1="216" x2="250" y2="216"/>
        <line class="road" x1="-50" y1="232" x2="250" y2="232"/>
        <!-- main avenue (Alameda) -->
        <line class="avenue" x1="-50" y1="250" x2="250" y2="-50"/>
        <line class="avenue" x1="-50" y1="120" x2="250" y2="150"/>
        <!-- secondary diagonal -->
        <line class="road" x1="250" y1="210" x2="-30" y2="-50"/>
        <!-- río Mapocho -->
        <path class="river" d="M-20 96 C 40 78 78 116 120 96 C 158 78 192 108 220 90"/>
      </g>
    </svg>
    <span class="loc-pin"></span>
  </div>
  <div class="pill-label">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.8"/></svg>
    <span>{t.locLabel}</span>
  </div>
  <div class="loc-body">
    <span class="loc-city">{t.locCity}</span>
    <span class="loc-meta"><span id="loc-time">— GMT-3</span> · {t.locRemote}</span>
  </div>
</div>
<script is:inline>
  (function () {
    function tick() {
      try {
        var s = new Intl.DateTimeFormat('en-GB', {
          hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Santiago',
        }).format(new Date());
        var el = document.getElementById('loc-time');
        if (el) el.textContent = s + ' GMT-3';
      } catch (_) {}
    }
    tick();
    setInterval(tick, 30000);
  })();
</script>
